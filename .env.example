SERPAPI_KEY=your_serpapi_key_here         # required — serpapi.com
GROQ_API_KEY=your_groq_key_here           # required — console.groq.com (free)
KIWI_API_KEY=your_kiwi_key_here           # optional — tequila.kiwi.com (connection search)
AMADEUS_CLIENT_ID=your_amadeus_id         # optional — developers.amadeus.com (free, real GDS data)
AMADEUS_CLIENT_SECRET=your_amadeus_secret # optional — same account as above
